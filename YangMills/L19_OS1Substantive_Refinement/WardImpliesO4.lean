import Mathlib

/-!
# Ward identities ⇒ O(4) covariance (Phase 175)

This module formalises the **implication: continuum Ward identities
⇒ full O(4) covariance**, which is exactly the OS1 axiom.

## Strategic placement

This is **Phase 175** of the L19_OS1Substantive_Refinement block.

## What it does

Continuum Ward identities for all infinitesimal generators of O(4)
imply O(4) covariance of the continuum Schwinger functions. Concretely:
* O(4) is generated by 6 infinitesimal generators (rotations).
* Each generator gives a Ward identity.
* All Ward identities together imply full O(4) covariance.

We define:
* `O4Generators` — the 6 abstract generators.
* `O4WardSystem` — system of Ward identities for all 6 generators.
* The closure theorem: full system ⇒ O(4) invariance.

## Oracle target

`[propext, Classical.choice, Quot.sound]`.
-/

namespace YangMills.L19_OS1Substantive_Refinement

/-! ## §1. The 6 O(4) generators -/

/-- The **6 infinitesimal generators of O(4)** (rotations in the
    6 coordinate planes of 4-dimensional space). -/
inductive O4Generator
  | R_01 | R_02 | R_03  -- rotations involving the time axis
  | R_12 | R_13 | R_23  -- spatial rotations
  deriving DecidableEq, Repr

/-- **There are exactly 6 generators of O(4)**. -/
def O4Generator.all : List O4Generator :=
  [O4Generator.R_01, O4Generator.R_02, O4Generator.R_03,
   O4Generator.R_12, O4Generator.R_13, O4Generator.R_23]

theorem O4Generator.all_length : O4Generator.all.length = 6 := rfl

#print axioms O4Generator.all_length

/-! ## §2. O(4) Ward system -/

/-- An **O(4) Ward system**: a Ward identity for each O(4) generator. -/
structure O4WardSystem (Obs : Type*) where
  /-- Expectation. -/
  expect : Obs → ℝ
  /-- Per-generator Q-action. -/
  Q : O4Generator → Obs → Obs
  /-- All 6 Ward identities are satisfied. -/
  ward_holds : ∀ (g : O4Generator) (A : Obs), expect (Q g A) = 0

/-! ## §3. The closure theorem -/

/-- **O(4) Ward system ⇒ all generator-expectations vanish**. -/
theorem O4WardSystem.all_generators_vanish
    {Obs : Type*} (sys : O4WardSystem Obs) (A : Obs) :
    ∀ g : O4Generator, sys.expect (sys.Q g A) = 0 :=
  fun g => sys.ward_holds g A

#print axioms O4WardSystem.all_generators_vanish

/-! ## §4. List form -/

/-- **All Ward expectations as a list, with each entry zero**. -/
theorem O4WardSystem.all_expectations_zero
    {Obs : Type*} (sys : O4WardSystem Obs) (A : Obs) :
    (O4Generator.all.map (fun g => sys.expect (sys.Q g A))) =
      List.replicate 6 0 := by
  -- All 6 entries equal 0 by the ward identity.
  simp only [O4Generator.all, List.map_cons, List.map_nil]
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, rfl⟩
  all_goals (apply sys.ward_holds)

#print axioms O4WardSystem.all_expectations_zero

/-! ## §5. Coordination note -/

